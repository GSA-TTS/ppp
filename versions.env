# Single source of truth for ppp's pinned toolchain versions.
#
# Everything that installs or documents a pinned tool version should read from
# HERE, not restate the number. Update a version in this one file, then:
#   - Makefile           sources it directly (include versions.env)
#   - .devcontainer      passes each as a build ARG (see .devcontainer/README.md)
#   - CI                 sources it for build-args
#
# Format: plain KEY=value so it is valid both as a Makefile `include` and as a
# shell `set -a; . versions.env` source. No spaces around '='; no export.

# Go language floor (must match the `go` directive in go.mod).
GO_VERSION=1.25

# Go dev tools (installed via `go install ...@<version>`).
GOIMPORTS_VERSION=v0.48.0
GOLANGCI_LINT_VERSION=v2.12.2
GOVULNCHECK_VERSION=v1.1.4

# Python addon tooling (installed into the dev-container venv).
MITMPROXY_VERSION=12.2.3
RUFF_VERSION=0.15.22
PYTEST_VERSION=8.4.2
PRECOMMIT_VERSION=4.6.0

# External CLIs bundled in the dev container.
PODMAN_VERSION=6.0.1
GITLEAKS_VERSION=8.30.1
GH_VERSION=2.96.0

# Pinned universal-contract release tag (fetched at dev-container build time).
PLAYBOOK_REF=v0.14.0
