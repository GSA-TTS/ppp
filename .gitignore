# Fallback cache for the universal behavioral contract — never commit.
# The canonical contract is provided by the environment; see README.
.agents/cache/

# Python bytecode cache
__pycache__/
*.py[cod]

# Go build artifacts
/bin/

# Agent session transcripts
session-*.md

# Git worktrees for parallel ticket work (kept inside the repo/workspace mount)
.worktrees/
